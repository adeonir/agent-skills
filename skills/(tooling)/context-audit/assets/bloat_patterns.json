{
  "_comment": "Map project markers (files at project root) to bloat directories that should appear in permissions.deny. Used by audit.py to flag missing deny rules. The 'always' block applies regardless of project type.",
  "always": [
    "Read(.git/objects/**)",
    "Read(*.lock)",
    "Read(*.log)",
    "Read(.cache/**)",
    "Read(tmp/**)"
  ],
  "by_marker": {
    "package.json": [
      "Read(node_modules/**)",
      "Read(dist/**)",
      "Read(build/**)",
      "Read(.next/**)",
      "Read(.nuxt/**)",
      "Read(coverage/**)",
      "Read(.turbo/**)"
    ],
    "Cargo.toml": [
      "Read(target/**)"
    ],
    "go.mod": [
      "Read(vendor/**)",
      "Read(bin/**)"
    ],
    "pyproject.toml": [
      "Read(__pycache__/**)",
      "Read(.venv/**)",
      "Read(*.egg-info/**)",
      "Read(.pytest_cache/**)",
      "Read(.mypy_cache/**)",
      "Read(.ruff_cache/**)"
    ],
    "requirements.txt": [
      "Read(__pycache__/**)",
      "Read(.venv/**)",
      "Read(venv/**)"
    ],
    "pom.xml": [
      "Read(target/**)",
      "Read(.m2/**)"
    ],
    "build.gradle": [
      "Read(build/**)",
      "Read(.gradle/**)"
    ],
    "build.gradle.kts": [
      "Read(build/**)",
      "Read(.gradle/**)"
    ],
    "composer.json": [
      "Read(vendor/**)"
    ],
    "Gemfile": [
      "Read(vendor/bundle/**)",
      "Read(.bundle/**)"
    ],
    "mix.exs": [
      "Read(_build/**)",
      "Read(deps/**)"
    ]
  }
}
